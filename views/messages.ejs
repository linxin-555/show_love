<%- include('partials/head', { title: '留言板' }) %>
<%- include('partials/header') %>

<div class="messages-page">
  <div class="messages-form-wrapper">
    <h2>留下你的祝福 &#9998;</h2>
    <form id="msgForm" class="msg-form">
      <div class="form-group">
        <input type="text" name="nickname" class="form-input" placeholder="你的昵称" required maxlength="20">
      </div>
      <div class="form-group">
        <textarea name="content" class="form-input form-textarea" placeholder="想说点什么..." required maxlength="500" rows="3"></textarea>
      </div>
      <button type="submit" class="btn btn-primary">发表留言</button>
    </form>
    <div class="form-error" id="msgError" style="display:none;"></div>
  </div>

  <div class="messages-list" id="messagesList">
    <% messages.slice().reverse().forEach(msg => { %>
      <div class="msg-card">
        <div class="msg-card-header">
          <strong><%= msg.nickname %></strong>
          <span class="msg-date"><%= new Date(msg.createdAt).toLocaleString('zh-CN') %></span>
        </div>
        <p><%= msg.content %></p>
        <% if (user) { %>
          <button class="btn btn-danger btn-sm delete-msg" onclick="deleteMsg('<%= msg.id %>')">删除</button>
        <% } %>
      </div>
    <% }) %>
    <% if (messages.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">&#128172;</div>
        <p>还没有留言，来说第一句话吧~</p>
      </div>
    <% } %>
  </div>
</div>

</main>

<script src="/js/messages.js"></script>
<script>
function logout() {
  fetch('/api/auth/logout', { method: 'POST' }).then(() => location.href = '/');
}
</script>
</body>
</html>
