<%- include('partials/head', { title: '我们的故事' }) %>
<%- include('partials/header') %>

<% const total = groups.reduce((s, g) => s + g.photos.length, 0); %>

<section class="hero">
  <h1 class="hero-title">
    <span class="heart-beat">&#10084;</span> 我们的故事
  </h1>
  <p class="hero-sub">每一张照片，都是最珍贵的回忆</p>
  <p class="photo-count"><%= total %> 张照片 · <%= groups.length %> 天</p>
</section>

<% if (total === 0) { %>
<div class="empty-state">
  <div class="empty-icon">&#128247;</div>
  <p>还没有照片，登录后开始上传吧~</p>
  <a href="/login" class="btn btn-primary">去上传</a>
</div>
<% } else { %>

<div class="timeline" id="timeline">
  <% groups.forEach(function(group, gi) { %>
  <div class="timeline-group">
    <div class="timeline-date">
      <span class="date-dot"></span>
      <span class="date-heart">&#10084;</span>
      <span class="date-text"><%= group.date %> <%= group.weekday %></span>
      <span class="date-count"><%= group.photos.length %> 张</span>
    </div>
    <div class="timeline-photos">
      <% group.photos.forEach(function(photo, pi) { var isHe = photo.uploadedBy === '他'; var idx = gi * 100 + pi; %>
      <div class="timeline-item"
           data-photo-id="<%= photo.id %>"
           data-original="/uploads/<%= photo.original %>"
           data-version="<%= photo.version || 0 %>"
           data-description="<%= photo.description || '' %>"
           data-index="<%= idx %>">
        <img src="/uploads/<%= photo.filename %>?v=<%= photo.version || 0 %>" alt="">
        <div class="timeline-item-info">
          <span class="ti-uploader<%= isHe ? ' he' : ' she' %>"><%= photo.uploadedBy %></span>
          <span class="ti-meta">
            <% if (photo.description) { %><span class="ti-desc"><%= photo.description.slice(0, 20) %><%= photo.description.length > 20 ? '...' : '' %></span><% } %>
            <span class="ti-time"><%= new Date(photo.uploadedAt).toLocaleTimeString('zh-CN', { hour:'2-digit', minute:'2-digit' }) %></span>
          </span>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
  <% }); %>
</div>

<% } %>

<div class="lightbox" id="lightbox">
  <span class="lightbox-close">&times;</span>
  <span class="lightbox-nav lightbox-prev">&lsaquo;</span>
  <span class="lightbox-nav lightbox-next">&rsaquo;</span>
  <div class="lightbox-main">
    <img src="" alt="" id="lightboxImg">
    <div class="lightbox-caption" id="lightboxCaption">
      <span class="lightbox-desc-text" id="lightboxDesc"></span>
      <% if (user) { %>
      <input type="text" class="lightbox-desc-input" id="lightboxDescInput" placeholder="添加描述..." maxlength="100" style="display:none;">
      <% } %>
    </div>
  </div>
  <div class="lightbox-counter" id="lightboxCounter"></div>
</div>

<footer class="footer">
  <p>Made with <span class="heart-beat">&#10084;</span> for you</p>
</footer>

</main>

<script src="/js/gallery.js"></script>
<script>
function logout() {
  fetch('/api/auth/logout', { method: 'POST' }).then(() => location.href = '/');
}
</script>
</body>
</html>
