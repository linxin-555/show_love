<%- include('partials/head', { title: '管理后台' }) %>
<%- include('partials/header') %>

<div class="admin-page">
  <section class="admin-section">
    <h2>上传照片</h2>
    <form id="uploadForm" class="upload-form">
      <div class="upload-zone" id="uploadZone">
        <div class="upload-icon">&#128247;</div>
        <p>点击选择或拖拽照片到此处</p>
        <p class="upload-hint">支持 JPG/PNG/GIF/WebP，单张不超过 20MB</p>
        <input type="file" name="photo" id="photoInput" accept="image/*" multiple style="display:none;">
        <div id="previewContainer" class="preview-row"></div>
      </div>
      <div class="upload-status" id="uploadStatus" style="display:none;"></div>
      <button type="submit" class="btn btn-primary" id="uploadBtn" disabled>上传选中照片</button>
    </form>
  </section>

  <section class="admin-section">
    <h2>已有照片（<span id="photoCount"><%= photos.length %></span> 张）</h2>
    <div class="admin-grid" id="adminGrid">
      <% photos.forEach(photo => { %>
        <div class="admin-grid-item" data-id="<%= photo.id %>">
          <img src="/uploads/<%= photo.filename %>?v=<%= photo.version || 0 %>" alt="">
          <div class="admin-item-info">
            <span><%= photo.uploadedBy %></span>
            <span><%= new Date(photo.uploadedAt).toLocaleDateString('zh-CN') %></span>
          </div>
          <div class="admin-item-actions">
            <button class="btn btn-sm rotate-btn" data-id="<%= photo.id %>" title="向右旋转 90°">&#x21BB;</button>
            <button class="btn btn-danger btn-sm delete-photo" data-id="<%= photo.id %>">删除</button>
          </div>
        </div>
      <% }) %>
      <% if (photos.length === 0) { %>
        <p class="empty-hint">暂无照片</p>
      <% } %>
    </div>
  </section>

  <section class="admin-section">
    <h2>留言管理</h2>
    <div class="admin-grid" id="msgGrid">
      <% messages.forEach(msg => { %>
        <div class="msg-card" data-id="<%= msg.id %>">
          <div class="msg-card-header">
            <strong><%= msg.nickname %></strong>
            <span class="msg-date"><%= new Date(msg.createdAt).toLocaleString('zh-CN') %></span>
          </div>
          <p><%= msg.content %></p>
          <button class="btn btn-danger btn-sm delete-msg" data-id="<%= msg.id %>">删除</button>
        </div>
      <% }) %>
      <% if (messages.length === 0) { %>
        <p class="empty-hint">暂无留言</p>
      <% } %>
    </div>
  </section>
</div>

</main>

<script>
let pendingFiles = [];

document.getElementById('uploadZone').addEventListener('click', () => {
  document.getElementById('photoInput').click();
});

document.getElementById('photoInput').addEventListener('change', handleFiles);

const uploadZone = document.getElementById('uploadZone');
uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('dragover'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
uploadZone.addEventListener('drop', e => {
  e.preventDefault();
  uploadZone.classList.remove('dragover');
  handleFiles({ target: { files: e.dataTransfer.files } });
});

function handleFiles(e) {
  const files = Array.from(e.target.files).filter(f => /\.(jpg|jpeg|png|gif|webp)$/i.test(f.name));
  pendingFiles = pendingFiles.concat(files);
  const container = document.getElementById('previewContainer');
  container.innerHTML = pendingFiles.map((f, i) =>
    '<div class="preview-item"><img src="' + URL.createObjectURL(f) + '" alt=""><span class="preview-remove" onclick="removePending(' + i + ')">&times;</span></div>'
  ).join('');
  document.getElementById('uploadBtn').disabled = pendingFiles.length === 0;
}

function removePending(i) {
  pendingFiles.splice(i, 1);
  document.getElementById('photoInput').value = '';
  handleFiles({ target: { files: [] } });
}

document.getElementById('uploadForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const statusEl = document.getElementById('uploadStatus');
  statusEl.style.display = 'block';
  statusEl.textContent = '上传中...';
  statusEl.className = 'upload-status loading';

  let uploaded = 0;
  for (const file of pendingFiles) {
    const fd = new FormData();
    fd.append('photo', file);
    try {
      const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.ok) uploaded++;
    } catch (err) {}
  }

  statusEl.textContent = '上传完成：' + uploaded + '/' + pendingFiles.length + ' 张成功';
  statusEl.className = uploaded === pendingFiles.length ? 'upload-status success' : 'upload-status error';
  pendingFiles = [];
  document.getElementById('previewContainer').innerHTML = '';
  document.getElementById('uploadBtn').disabled = true;
  location.reload();
});

document.querySelectorAll('.rotate-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const id = btn.dataset.id;
    try {
      const res = await fetch('/api/admin/photos/' + id + '/rotate', { method: 'POST' });
      if (res.ok) location.reload();
      else alert('旋转失败，请重试');
    } catch (err) { alert('旋转失败'); }
  });
});

document.querySelectorAll('.delete-photo').forEach(btn => {
  btn.addEventListener('click', async () => {
    if (!confirm('确定删除这张照片？')) return;
    const id = btn.dataset.id;
    const res = await fetch('/api/admin/photos/' + id, { method: 'DELETE' });
    if (res.ok) location.reload();
  });
});

document.querySelectorAll('.delete-msg').forEach(btn => {
  btn.addEventListener('click', async () => {
    if (!confirm('确定删除这条留言？')) return;
    const id = btn.dataset.id;
    const res = await fetch('/api/messages/' + id, { method: 'DELETE' });
    if (res.ok) location.reload();
  });
});

function logout() {
  fetch('/api/auth/logout', { method: 'POST' }).then(() => location.href = '/');
}
</script>
</body>
</html>
